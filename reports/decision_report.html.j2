<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Decision Report — {{ audit_id }}</title>
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; max-width: 860px; margin: 40px auto; color: #333; line-height: 1.6; }
    h1 { border-bottom: 2px solid #444; padding-bottom: 8px; }
    h2 { color: #555; margin-top: 28px; }
    .badge { display: inline-block; padding: 4px 14px; border-radius: 12px; font-weight: bold; font-size: 1.1em; }
    .approve { background: #d4edda; color: #155724; }
    .review  { background: #fff3cd; color: #856404; }
    .reject  { background: #f8d7da; color: #721c24; }
    .risk-bar-outer { background: #e9ecef; border-radius: 6px; height: 18px; width: 100%; margin: 6px 0; }
    .risk-bar-inner { height: 18px; border-radius: 6px; background: linear-gradient(90deg, #28a745, #ffc107, #dc3545); }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #dee2e6; }
    th { background: #f8f9fa; font-weight: 600; }
    .up { color: #dc3545; }
    .down { color: #28a745; }
    .neutral { color: #6c757d; }
    .meta { font-size: 0.85em; color: #6c757d; margin-top: 24px; }
  </style>
</head>
<body>

<h1>Procurement Decision Report</h1>
<p><strong>Audit ID:</strong> {{ audit_id }}<br>
   <strong>Timestamp:</strong> {{ timestamp }}</p>

<h2>Decision</h2>
<span class="badge {{ decision }}">{{ decision | upper }}</span>
&nbsp;&nbsp;
<strong>Fused Risk: {{ (fused_risk * 100) | round(1) }}%</strong>

<div class="risk-bar-outer">
  <div class="risk-bar-inner" style="width: {{ (fused_risk * 100) | round(1) }}%;"></div>
</div>

<p><em>{{ summary }}</em></p>

<h2>Input Features</h2>
<table>
  <tr><th>Feature</th><th>Value</th></tr>
  {% for key, val in inputs.items() %}
  <tr><td>{{ key }}</td><td>{{ val }}</td></tr>
  {% endfor %}
</table>

<h2>ML Model Output</h2>
<table>
  <tr><th>Feature</th><th>Importance</th><th>Value</th><th>Direction</th></tr>
  {% for fc in feature_contributions %}
  <tr>
    <td>{{ fc.feature }}</td>
    <td>{{ (fc.importance * 100) | round(1) }}%</td>
    <td>{{ fc.value }}</td>
    <td>
      {% if fc.direction == 'increases_risk' %}<span class="up">&#9650; increases risk</span>
      {% elif fc.direction == 'decreases_risk' %}<span class="down">&#9660; decreases risk</span>
      {% else %}<span class="neutral">— neutral</span>{% endif %}
    </td>
  </tr>
  {% endfor %}
</table>
<p>ML risk score: <strong>{{ (ml_risk * 100) | round(1) }}%</strong>
   (label: {{ ml_label }})</p>

<h2>Fuzzy Inference</h2>
<p>Fuzzy risk: <strong>{{ (fuzzy_risk * 100) | round(1) }}%</strong></p>
<table>
  <tr><th>Rule</th><th>Activation</th><th>Consequent</th><th>Condition</th></tr>
  {% for rule in rule_activations %}
  <tr>
    <td>{{ rule.rule_name }}</td>
    <td>{{ rule.strength }}</td>
    <td>{{ rule.consequent | upper }}</td>
    <td><em>{{ rule.description }}</em></td>
  </tr>
  {% endfor %}
</table>

<h2>Evidence Fusion</h2>
<p>Strategy: <strong>{{ fusion_strategy }}</strong> &nbsp;|&nbsp;
   Conflict index: <strong>{{ conflict_index }}</strong> &nbsp;|&nbsp;
   Confidence: <strong>{{ (fusion_confidence * 100) | round(1) }}%</strong></p>
<table>
  <tr><th>Source</th><th>Risk Score</th><th>Contribution Weight</th></tr>
  {% for fc in fusion_contributions %}
  <tr>
    <td>{{ fc.source }}</td>
    <td>{{ (fc.risk_score * 100) | round(1) }}%</td>
    <td>{{ (fc.contribution_weight * 100) | round(1) }}%</td>
  </tr>
  {% endfor %}
</table>

<div class="meta">
  Generated by interpretable-decision-modules &mdash; research prototype.
  This report is for demonstration purposes only.
</div>

</body>
</html>
